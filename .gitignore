# Chuck's List Builder — .gitignore

# --- Sensitive / local config ---
.env
*.env
secrets.py
config_local.py

# --- Data files (never commit) ---
data/
contacts/
*.csv
*.xlsx
*.ods
*.ods.bak
*.zip

# --- Generated outputs ---
*final_output.html
*Bulletin.html
*Events.html

# --- Media / assets ---
Images/
*.png
*.jpg
*.jpeg
*.pdf

# --- Logs ---
logs/
*.log

# --- Python ---
__pycache__/
*.py[cod]
venv/
.venv/

# --- Editor / OS ---
.vscode/settings.json
*.swp
.DS_Store
Thumbs.db